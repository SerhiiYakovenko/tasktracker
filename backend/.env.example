# TaskTracker backend configuration.
# Copy this file to `.env` and adjust values for your environment.
# Never commit a real `.env` file or real secrets.

# Application
APP_NAME=TaskTracker
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database. SQLite by default; swap for a Postgres URL in production, e.g.
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/tasktracker
DATABASE_URL=sqlite:///./data/app.db

# Security. CHANGE THIS in any non-local environment.
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_ALGORITHM=HS256

# CORS. Comma-separated list of allowed origins for the frontend.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Seed data (used by app/seed.py). Demo credentials only.
SEED_USER_EMAIL=demo@tasktracker.dev
SEED_USER_PASSWORD=change-me
SEED_USER_NAME=Demo User
